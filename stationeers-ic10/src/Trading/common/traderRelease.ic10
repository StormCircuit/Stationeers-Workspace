#uses buttons to activate trader pad
alias button1 d0
alias button2 d1
alias button3 d2
alias pad1 d3
alias pad2 d4
alias pad3 d5

monitorLoop:

brdns button1 4
l r0 button1 Setting
breq r0 0 2
s pad1 Activate 1

brdns button2 4
l r0 button2 Setting
breq r0 0 2
s pad2 Activate 1

brdns button3 4
l r0 button3 Setting
breq r0 0 2
s pad3 Activate 1

yield
j monitorLoop