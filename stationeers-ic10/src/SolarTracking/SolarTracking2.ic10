
define SolarSensor HASH("Solar Array 1 Solar Sensor")

start:
push HASH("Solar Array 1-1")
push HASH("Solar Array 1-2")
push HASH("Solar Array 1-3")
push HASH("Solar Array 1-4")
push HASH("Solar Array 1-5")

panelmove:
yield
pop r0
lbn r1 1945473703 r0 Horizontal Maximum
sbn 1945473703 r0 Horizontal r1
lbn r1 1945473703 r0 Vertical Maximum
sbn 1945473703 r0 Vertical r1
bgt sp 0 panelmove

j start