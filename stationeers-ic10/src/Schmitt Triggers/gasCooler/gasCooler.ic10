
alias gasTempDevice d0

alias currentTemp r4

define minTempKelvin 267
define maxTempKelvin 268

#simple schmitt trigger

noCooling:
sb -2113838091 On 0
l currentTemp gasTempDevice Temperature
s db Setting currentTemp
bgeal currentTemp maxTempKelvin startCooling
yield
j noCooling

startCooling:
sb -2113838091 On 1
l currentTemp gasTempDevice Temperature
s db Setting currentTemp
blt currentTemp minTempKelvin noCooling
yield
j startCooling