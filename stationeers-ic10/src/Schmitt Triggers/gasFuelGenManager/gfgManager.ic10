
alias ratioChip d0

define gfgHash 1165997963

define minRatio 25
define maxRatio 50


#simple schmitt trigger

start:

noGen:
sb gfgHash On 0
l r0 ratioChip Setting
s db Setting r0
blt r0 minRatio onGen
yield
j noGen

onGen:
sb gfgHash On 1
l r0 ratioChip Setting
s db Setting r0
bgt r0 maxRatio noGen
yield
j onGen